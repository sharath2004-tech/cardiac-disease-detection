        <mxCell id="p22" value="P2.2&#xa;Data Formatting &amp; Validation" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="260" y="230" width="180" height="100" as="geometry" />
        </mxCell>

        <mxCell id="db" value="D2: Patient Health Database" style="shape=partialRectangle;whiteSpace=wrap;html=1;left=0;right=0;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="260" y="400" width="200" height="40" as="geometry" />
        </mxCell>

        <mxCell id="e1" value="Health Parameters" style="endArrow=block;endFill=1;strokeWidth=2;verticalAlign=bottom;" edge="1" parent="1" source="patient" target="p21">
